{
  "name": "oxen-queue",
  "version": "2.0.0",
  "description": "A no-frills, resilient worker queue backed by MySQL.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./compat": {
      "types": "./dist/compat.d.ts",
      "default": "./dist/compat.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=24.0.0"
  },
  "author": "Opteo Team <support@opteo.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/Opteo/oxen-queue.git"
  },
  "scripts": {
    "build": "tsup src/index.ts src/compat.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:integration": "OXEN_INTEGRATION=1 bun test test/integration"
  },
  "dependencies": {
    "mysql2": "3.16.3",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/bun": "^1.2.13",
    "@types/node": "^24.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3"
  },
  "license": "MIT"
}
